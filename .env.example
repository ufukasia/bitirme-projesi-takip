# ─────────────────────────────────────────────────────────────────────────────
# Bitirme Proje Takip — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and should NEVER be committed to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to the project root)
DB_PATH=project_tracker.db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Default password assigned to every new user on first sync.
# Users are forced to change this on their first login.
DEFAULT_PASSWORD=12345

# Minimum length for user-chosen passwords (must be >= 6)
MIN_PASSWORD_LEN=6

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated normalized keys (lowercase, no spaces, no diacritics)
# of advisor accounts that have admin/database-reset privileges.
ADMIN_ADVISOR_KEYS=drufukasil,drufukasl

# Name used as advisor fallback when the CSV row has no advisor column.
DEFAULT_ADVISOR=Dr. UFUK ASIL

# ── File Uploads ──────────────────────────────────────────────────────────────
# Directory where student evidence files are saved (relative path).
UPLOADS_DIR=uploads

# ── Localisation ──────────────────────────────────────────────────────────────
# Default UI language: 'tr' (Turkish) or 'en' (English)
DEFAULT_LANGUAGE=tr
